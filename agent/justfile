# Install Rust toolchain (if needed)
setup:
    rustup show

# Build the agent in debug mode
build:
    cargo build

# Build in release mode
build-release:
    cargo build --release

# Start the agent gRPC server (debug)
start:
    cargo run

# Start in release mode
start-release:
    cargo run --release

# Send a test prompt to the running agent (no grpcurl dependency).
# Optional image path usage:
#   just prompt "compare this booking" image="/abs/path/to/ticket.jpg"
prompt message session="test" image="":
    SESSION="{{session}}" MESSAGE="{{message}}" IMAGE="{{image}}" /Users/gabrielindrei/site_pastrami/vibehack-2026/ocr/.venv/bin/python -c 'import os, sys, grpc; sys.path.insert(0, "/tmp/agent_grpc_test"); import agent_pb2, agent_pb2_grpc; message = os.environ["MESSAGE"]; image = os.environ.get("IMAGE", ""); user_message = f"{message}\n[image_path={image}]" if image else message; channel = grpc.insecure_channel("localhost:50052"); grpc.channel_ready_future(channel).result(timeout=5); stub = agent_pb2_grpc.AgentServiceStub(channel); resp = stub.Chat(agent_pb2.ChatRequest(session_id=os.environ["SESSION"], user_message=user_message), timeout=240); print(resp.reply)'

# Check + clippy
lint:
    cargo fmt --check
    cargo clippy -- -D warnings
