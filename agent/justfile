# Install Rust toolchain (if needed)
setup:
    rustup show

# Build the agent in debug mode
build:
    cargo build

# Build in release mode
build-release:
    cargo build --release

# Start the agent gRPC server (debug)
start:
    cargo run

# Start in release mode
start-release:
    cargo run --release

# Send a test prompt to the running agent (no grpcurl dependency).
# Optional image path usage:
#   just prompt "compare this booking" image="/abs/path/to/ticket.jpg"
prompt message image="" session="test":
    python3 -c "import json, sys; msg='{{message}}'; img='{{image}}'; full=msg+'\n[image_path='+img+']' if img else msg; print(json.dumps({'session_id':'{{session}}','user_message':full}))" \
    | grpcurl -plaintext \
        -proto ../proto/agent.proto \
        -d @ \
        '[::1]:50052' \
        agent.AgentService/Chat

# Test OCR with a local image file (single required arg avoids just's optional-param quirk)
# Usage: just ocr /abs/path/to/ticket.jpg
ocr image:
    python3 -c "import json; print(json.dumps({'session_id':'test','user_message':'Here is my booking screenshot, please extract all the flight details.\n[image_path={{image}}]'}))" \
    | grpcurl -plaintext \
        -proto ../proto/agent.proto \
        -d @ \
        '[::1]:50052' \
        agent.AgentService/Chat

# Check + clippy
lint:
    cargo fmt --check
    cargo clippy -- -D warnings
