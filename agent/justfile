# Install Rust toolchain (if needed)
setup:
    rustup show

# Build the agent in debug mode
build:
    cargo build

# Build in release mode
build-release:
    cargo build --release

# Start the agent gRPC server (debug)
start:
    cargo run

# Start in release mode
start-release:
    cargo run --release

# Send a test prompt to the running agent (requires grpcurl + server running via `just start`)
# Optional image path usage:
#   just prompt "compare this booking" image="/abs/path/to/ticket.jpg"
prompt message session="test" image="":
    SESSION="{{session}}" MESSAGE="{{message}}" IMAGE="{{image}}" python3 -c 'import json, os, pathlib; message = os.environ["MESSAGE"]; image = os.environ.get("IMAGE", ""); message = f"{message}\n[image_path={image}]" if image else message; pathlib.Path("/tmp/agent_prompt_payload.json").write_text(json.dumps({"session_id": os.environ["SESSION"], "user_message": message}))'
    grpcurl -plaintext \
        -proto proto/agent.proto \
        -d @ \
        '[::1]:50052' \
        agent.AgentService/Chat < /tmp/agent_prompt_payload.json

# Check + clippy
lint:
    cargo fmt --check
    cargo clippy -- -D warnings
