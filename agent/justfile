# Install Rust toolchain (if needed)
setup:
    rustup show

# Build the agent in debug mode
build:
    cargo build

# Build in release mode
build-release:
    cargo build --release

# Start the agent gRPC server (debug)
start:
    cargo run

# Start in release mode
start-release:
    cargo run --release

# Send a test prompt to the running agent (requires grpcurl + server running via `just start`)
# Optional image path usage:
#   just prompt "compare this booking" image="/abs/path/to/ticket.jpg"
prompt message session="test" image="":
    payload=$$(SESSION="{{session}}" MESSAGE="{{message}}" IMAGE="{{image}}" python3 -c 'import json, os; m=os.environ["MESSAGE"]; i=os.environ["IMAGE"]; m=f"{m}\n[image_path={i}]" if i else m; print(json.dumps({"session_id": os.environ["SESSION"], "user_message": m}))'); \
    grpcurl -plaintext \
        -proto proto/agent.proto \
        -d "$$payload" \
        '[::1]:50052' \
        agent.AgentService/Chat

# Check + clippy
lint:
    cargo fmt --check
    cargo clippy -- -D warnings
