{
  "name": "vibehack-2026",
  "version": "1.0.0",
  "description": "Vibehack 2026 hackathon submission — AI-powered WhatsApp assistant",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r dotenv/config -r reflect-metadata src/main.ts",
    "dev:infra:up": "docker compose -f dev.yaml up -d",
    "dev:infra:down": "docker compose -f dev.yaml down",
    "dev:infra:logs": "docker compose -f dev.yaml logs -f",
    "dev:all": "npm run dev:infra:up && npm run start:dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
