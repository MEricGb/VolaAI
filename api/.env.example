POSTGRES_USER="vibehack"
POSTGRES_PASSWORD="vibehack_pass"
DATABASE_URL="postgresql://vibehack:vibehack_pass@localhost:5432/vibehack?schema=public"

REDIS_URL="redis://localhost:6379"
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="admin"
MINIO_SECRET_KEY="password"
MINIO_BUCKET="whatsapp-media"
# Set to "true" if your MinIO endpoint uses TLS
MINIO_USE_SSL="false"

# Media ingestion (WhatsApp attachments)
# Attachments are stored in MinIO and served by the API at GET /media/:key
# Public base URL used to build media URLs for the agent/OCR (defaults to PUBLIC_BASE_URL).
MEDIA_PUBLIC_BASE_URL=""

# Local public URL used for Twilio webhook callback when tunneling with ngrok.
# Updated automatically by: npm run ngrok:sync
PUBLIC_BASE_URL=""
TWILIO_WEBHOOK_URL=""

# Twilio credentials
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# Twilio Conversations API (for WhatsApp group chat)
TWILIO_MESSAGE_SERVICE_SID=""
TWILIO_CONTENT_SID=""
# Optional override for Twilio Conversations Media Content Service base URL.
# Default tries: https://mcs.twilio.com then https://mcs.us1.twilio.com
TWILIO_MCS_BASE_URL=""

# Only used for the landing page instructions (Twilio WhatsApp Sandbox join phrase).
# Example: "join declared-daughter" (or whatever Twilio shows in your Sandbox Participants page).
TWILIO_SANDBOX_JOIN_PHRASE="join declared-daughter"

# AI trigger prefix required for the bot to respond (in 1:1 and groups)
TWILIO_AI_TRIGGER="@vola"

# URL of the Rust agent gRPC service
AGENT_GRPC_URL="localhost:50052"
