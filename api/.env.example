POSTGRES_USER="vibehack"
POSTGRES_PASSWORD="vibehack_pass"
DATABASE_URL="postgresql://vibehack:vibehack_pass@localhost:5432/vibehack?schema=public"

REDIS_URL="redis://localhost:6379"
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="admin"
MINIO_SECRET_KEY="password"
MINIO_BUCKET="whatsapp-media"

# Local public URL used for Twilio webhook callback when tunneling with ngrok.
# Updated automatically by: npm run ngrok:sync
PUBLIC_BASE_URL=""
TWILIO_WEBHOOK_URL=""

# Twilio credentials
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# Twilio Conversations API (for WhatsApp group chat)
TWILIO_MESSAGE_SERVICE_SID=""
TWILIO_CONTENT_SID=""

# URL of the Rust agent gRPC service
AGENT_GRPC_URL="localhost:50052"
