generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum WhatsAppGroupMemberStatus {
  INVITED
  ACTIVE
  LEFT
}

model User {
  id            String               @id @default(uuid())
  phone         String               @unique
  name          String?
  credits       Int                  @default(0)
  memberships   WhatsAppGroupMember[]
  ownedGroups   WhatsAppGroup[]      @relation("WhatsAppGroupOwner")
  sentMessages  WhatsAppGroupMessage[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("users")
}

model WhatsAppGroup {
  id               String                @id @default(uuid())
  name             String
  joinCode         String                @unique
  conversationSid  String?               @unique
  chatbotEnabled   Boolean               @default(true)
  ownerId          String?
  owner            User?                 @relation("WhatsAppGroupOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members          WhatsAppGroupMember[]
  messages         WhatsAppGroupMessage[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@map("whatsapp_groups")
}

model WhatsAppGroupMember {
  id             String                     @id @default(uuid())
  groupId        String
  userId         String?
  phone          String
  status         WhatsAppGroupMemberStatus  @default(INVITED)
  invitedAt      DateTime                   @default(now())
  joinedAt       DateTime?
  lastInboundAt  DateTime?
  user           User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  group          WhatsAppGroup              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@unique([groupId, phone])
  @@index([phone, status])
  @@map("whatsapp_group_members")
}

model WhatsAppGroupMessage {
  id               String           @id @default(uuid())
  groupId          String
  senderUserId     String?
  senderPhone      String
  body             String
  group            WhatsAppGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderUser       User?            @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())

  @@index([groupId, createdAt])
  @@map("whatsapp_group_messages")
}

model UserMedia {
  id          String   @id @default(uuid())
  userPhone   String   @map("user_phone")
  minioUrl    String   @map("minio_url")
  contentType String   @map("content_type")
  fileSize    Int?     @map("file_size")
  sessionId   String?  @map("session_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("user_media")
}
